APP_ENV=production
APP_NAME=memory-chat-service
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Optional. If set, every API request must include: X-API-Key: <SERVICE_API_KEY>
SERVICE_API_KEY=

# LLM provider settings. DeepSeek uses an OpenAI-compatible API.
DEEPSEEK_API_KEY=my-key
LLM_BASE_URL=https://api.deepseek.com
LLM_CHAT_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=800

# mem0 settings
MEM0_COLLECTION=chat_memories
MEM0_TELEMETRY=False
MEM0_LLM_PROVIDER=openai
MEM0_LLM_MODEL=deepseek-v4-flash
MEM0_EMBEDDER_PROVIDER=fastembed
MEM0_EMBEDDER_MODEL=BAAI/bge-small-en-v1.5
MEM0_EMBEDDER_DIMS=384
QDRANT_PATH=./storage/qdrant
MEM0_HISTORY_DB_PATH=./storage/mem0_history.db
MEMORY_DEBUG_LOG_PATH=./storage/memory_debug_logs.jsonl
MEMORY_PROFILE_PATH=./storage/personality_profiles.json
SUMMARY_INTERVAL_SECONDS=86400
SUMMARY_MEMORY_BATCH_SIZE=100
DECAY_MEDIUM_PENALTY=0.35
DECAY_STRONG_PENALTY=0.75
SUMMARY_RETENTION_BOOST=0.6
